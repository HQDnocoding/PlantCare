# ============================================================
# AI Chat Service - Environment Variables
# ============================================================
# Python FastAPI service for disease detection

# ============================================================================
# AI/ML API KEYS (REQUIRED)
# ============================================================================
# Gemini API Key - Get from: https://ai.google.dev/
GEMINI_API_KEY=your_google_gemini_api_key_from_ai_studio

# Hugging Face API Token - Get from: https://huggingface.co/settings/tokens
# Used for downloading embeddings models (BAAI/bge-m3)
HF_TOKEN=your_huggingface_api_token_for_bge_embeddings

# ============================================================================
# FIREBASE CONFIGURATION (for image uploads)
# ============================================================================
# Firebase Service Account JSON (complete JSON string)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"plant-55586",...}

# Firebase Storage Bucket URL
FIREBASE_STORAGE_BUCKET=plant-55586.firebasestorage.app

# ============================================================================
# CNN MODEL CONFIGURATION
# ============================================================================
# Path to CNN weights file
MODEL_WEIGHTS_PATH_2=best_loss.pth

# Minimum confidence threshold for disease predictions (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.6

# Model architecture name
MODEL_NAME=mobilenetv4_conv_medium.e500_r224_in1k

# Number of disease classes the model can detect
NUM_CLASSES=6

# ============================================================================
# RAG (Retrieval-Augmented Generation) CONFIGURATION
# ============================================================================
# Path to Chroma vector database
CHROMA_DB_PATH_2=chroma_db_700_120

# Embedding model name (used with Hugging Face)
MODEL_EMBEDDING=BAAI/bge-m3

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Database credentials (same as other services)
POSTGRES_USER=plant_auth
POSTGRES_PASSWORD=your_secure_password_here

# Database connection settings
DB_HOST=localhost              # local dev: localhost, docker: postgres-ai-chat
DB_PORT=5440                   # local dev: 5440, docker: 5432
DB_NAME=plant_chat_db
DB_POOL_SIZE=10                # SQLAlchemy connection pool size
DB_MAX_OVERFLOW=20             # Max overflow connections

# ============================================================================
# INTERNAL SECURITY
# ============================================================================
# Shared secret for inter-service communication
INTERNAL_SECRET=your_internal_secret_change_this_at_least_64_chars

# Admin secret key (optional - for future admin endpoints)
ADMIN_SECRET_KEY=your_admin_secret_key_change_in_production

# ============================================================================
# SERVICE CONFIGURATION (Optional)
# ============================================================================
# Server port
PORT=8000

# Logging level
LOG_LEVEL=INFO

# CORS allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# IDEMPOTENCY CACHE (Optional - if database is not shared)
# ============================================================================
# Cache TTL in seconds (24 hours by default)
CACHE_TTL=86400

# Cleanup interval in milliseconds (6 hours by default)
CLEANUP_INTERVAL_MS=21600000
