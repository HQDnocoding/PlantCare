# # ============================================================
# # Plant App Backend - Environment Variables
# # ============================================================
# # Copy this file to .env and fill in your actual values
# # DO NOT commit .env to git (add to .gitignore)
# # ============================================================

# # ============ INFRASTRUCTURE ============
# DOCKER_COMPOSE_VERSION=3.9
# SPRING_PROFILES_ACTIVE=docker

# # ============================================================================
# # POSTGRES DATABASE ============
# # ============================================================================
# # REQUIRED: PostgreSQL credentials (same for all databases)
# POSTGRES_USER=plant_auth
# POSTGRES_PASSWORD=your_secure_password_here_change_this

# # Database Names (one per service)
# POSTGRES_DB=plant_auth_db               # Auth Service
# SCAN_DB=plant_scan_db                   # Scan Service
# USER_DB=plant_user_db                   # User Service
# COMMUNITY_DB=plant_community_db         # Community Service
# NOTIFICATION_DB=plant_notification_db   # Notification Service
# ADMIN_DB=plant_admin_db                 # Admin Service (optional)
# AI_CHAT_DB=plant_ai_chat_db             # AI Chat Service (PostgreSQL backend)

# # ============================================================================
# # REDIS CACHE (REQUIRED - used by Auth, Community, User, Scan)
# # ============================================================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_change_this
# REDIS_TIMEOUT=2000ms

# # ============================================================================
# # KAFKA MESSAGE QUEUE (REQUIRED)
# # ============================================================================
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
# KAFKA_ADVERTISED_HOST_NAME=kafka
# KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# # ============================================================================
# # ELASTICSEARCH (REQUIRED for Search Service)
# # ============================================================================
# ELASTICSEARCH_URIS=http://elasticsearch:9200
# ELASTICSEARCH_HOST=elasticsearch
# ELASTICSEARCH_PORT=9200
# ELASTICSEARCH_DISCOVERY_SEED_HOSTS=elasticsearch
# ELASTICSEARCH_CLUSTER_INITIAL_MASTER_NODES=elasticsearch

# # ============================================================================
# # API GATEWAY & SERVICE PORTS
# # ============================================================================
# GATEWAY_PORT=8080

# # Service Ports
# AUTH_PORT=8081
# SCAN_PORT=8082
# USER_PORT=8083
# COMMUNITY_PORT=8084
# SEARCH_PORT=8085
# NOTIFICATION_PORT=8086
# ADMIN_PORT=8087
# CHAT_PORT=8000

# # ============================================================================
# # SERVICE URLS (for Feign/REST clients - Docker internal networking)
# # ============================================================================
# AUTH_SERVICE_URL=http://auth-service:8081
# AUTH_SERVICE_HOST=auth-service
# SCAN_SERVICE_URL=http://scan-service:8082
# SCAN_SERVICE_HOST=scan-service
# USER_SERVICE_URL=http://user-service:8083
# USER_SERVICE_HOST=user-service
# COMMUNITY_SERVICE_URL=http://community-service:8084
# COMMUNITY_SERVICE_HOST=community-service
# SEARCH_SERVICE_URL=http://search-service:8085
# NOTIFICATION_SERVICE_URL=http://notification-service:8086
# CHAT_SERVICE_URL=http://ai-chat:8000

# # ============================================================================
# # DATABASE CONNECTIONS (Spring Data JDBC/JPA)
# # ============================================================================
# # Format: jdbc:postgresql://hostname:port/database_name
# # Note: Each service has its own database
# DB_URL=jdbc:postgresql://postgres-auth:5432/plant_auth_db
# DB_USERNAME=${POSTGRES_USER}
# DB_PASSWORD=${POSTGRES_PASSWORD}

# # ============================================================================
# # SECURITY - JWT (Auth Service)
# # ============================================================================
# # Generate JWT_SECRET with: openssl rand -base64 32
# JWT_SECRET=your_jwt_secret_key_generate_with_openssl_change_this
# JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=2592000    # 30 days
# JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=3888000   # 45 days

# # ============================================================================
# # SECURITY - INTERNAL SERVICE COMMUNICATION
# # ============================================================================
# # Shared secret between services for X-Internal-Secret header validation
# # REQUIRED: All services must use the same value
# INTERNAL_SECRET=your_internal_secret_change_this_at_least_64_chars

# # ============================================================================
# # OAUTH2 - GOOGLE (Auth Service)
# # ============================================================================
# # Get from: https://console.cloud.google.com/credentials
# GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# # ============================================================================
# # OAUTH2 - FACEBOOK (Auth Service)
# # ============================================================================
# # Get from: https://developers.facebook.com/apps/
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret

# # ============================================================================
# # FIREBASE (for Image Uploads - Scan, User, Community Services)
# # ============================================================================
# # Firebase Storage bucket URL
# FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_url.appspot.com
# FIREBASE_CREDENTIALS_PATH=/firebase-key.json

# # For AI Chat Service - Firebase Auth credentials (JSON format)
# # Optional: Only needed if running chat-service
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"plant-55586",...}

# # ============================================================================
# # AI CHAT SERVICE (Python FastAPI)
# # ============================================================================
# # Gemini API key for disease detection AI
# GEMINI_API_KEY=your_gemini_api_key_here

# # Hugging Face token for model downloads
# HF_TOKEN=your_huggingface_token_here

# # Model configuration
# MODEL_WEIGHTS_PATH_2=/app/app/best_loss.pth
# CONFIDENCE_THRESHOLD=0.6
# MODEL_NAME=mobilenetv4_conv_medium.e500_r224_in1k
# NUM_CLASSES=6
# CHROMA_DB_PATH_2=/app/app/chroma_db_700_120
# MODEL_EMBEDDING=BAAI/bge-m3

# # ============================================================================
# # SPRING SECURITY (Community Service - Basic Auth for Actuator)
# # ============================================================================
# # Used for HTTP Basic Authentication on management endpoints
# SPRING_SECURITY_USER_NAME=admin
# SPRING_SECURITY_USER_PASSWORD=change_this_secure_password

# # ============================================================================
# # CORS & HEADERS
# # ============================================================================
# # Comma-separated list of allowed origins (for @CrossOrigin and CORS filters)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# # ============================================================================
# # LOGGING (Optional - for debugging)
# # ============================================================================
# LOG_LEVEL=INFO
# LOG_LEVEL_SPRING=WARN
# LOG_LEVEL_HIBERNATE=WARN
# LOG_LEVEL_KAFKA=WARN

# # ============================================================================
# # IDEMPOTENCY & CACHING (Services configuration)
# # ============================================================================
# # TTL for idempotency cache (seconds) - 24 hours
# CACHE_IDEMPOTENCY_TTL=86400
# # Cleanup interval for expired idempotency records (milliseconds) - 6 hours
# IDEMPOTENCY_CLEANUP_INTERVAL_MS=21600000

# # Cache TTL for other entities (seconds)
# CACHE_AUTHOR_TTL=300        # 5 minutes
# CACHE_VOTE_COUNT_TTL=60     # 1 minute

# # ============================================================================
# # OUTBOX PATTERN (for transactional event publishing)
# # ============================================================================
# OUTBOX_MAX_RETRIES=5
# OUTBOX_INITIAL_WAIT_SECONDS=60

# # ============ LOGGING ============
# LOG_LEVEL=INFO
# LOG_LEVEL_SPRING=WARN
# LOG_LEVEL_HIBERNATE=WARN
# LOGGING_FILE_NAME=/var/log/spring/app.log
# LOGGING_FILE_MAX_SIZE=10MB
# LOGGING_FILE_MAX_HISTORY=7
# LOGGING_FILE_TOTAL_SIZE_CAP=500MB

# # ============ OAUTH2 - GOOGLE ============
# # REQUIRED: Get from https://console.cloud.google.com
# GOOGLE_CLIENT_ID=your_google_client_id_from_console
# GOOGLE_CLIENT_SECRET=your_google_client_secret_from_console

# # ============ OAUTH2 - FACEBOOK ============
# # REQUIRED: Get from https://developers.facebook.com
# FACEBOOK_APP_ID=your_facebook_app_id_from_console
# FACEBOOK_APP_SECRET=your_facebook_app_secret_from_console

# # ============ AI CHAT SERVICE (Optional) ============
# # Only needed if running chat-service
# GEMINI_API_KEY=your_google_gemini_api_key_from_ai_studio
# HF_TOKEN=your_huggingface_api_token_for_bge_embeddings
# CONFIDENCE_THRESHOLD=0.6
# MODEL_NAME=mobilenetv4_conv_medium.e500_r224_in1k
# NUM_CLASSES=6
# MODEL_EMBEDDING=BAAI/bge-m3

# # ============ OUTBOX PATTERN - EVENT RETRY ============
# OUTBOX_MAX_RETRIES=5
# OUTBOX_INITIAL_WAIT_SECONDS=60

# # ============ CACHE ============
# CACHE_AUTHOR_TTL=300
# CACHE_IDEMPOTENCY_TTL=86400

# # ============ HEALTH CHECK ============
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus

# # ============ APPLICATION SETTINGS ============
# APP_NAME=plant-app-backend
# APP_VERSION=1.0.0
# ENVIRONMENT=docker

# # ============ TIMEOUTS (milliseconds) ============
# CONNECTION_TIMEOUT=5000
# READ_TIMEOUT=10000
# WRITE_TIMEOUT=10000

# # ============ CONNECTION POOL ============
# HIKARI_MAXIMUM_POOL_SIZE=20
# HIKARI_MINIMUM_IDLE=5
# HIKARI_CONNECTION_TIMEOUT=30000
# HIKARI_IDLE_TIMEOUT=600000
# HIKARI_MAX_LIFETIME=1800000
