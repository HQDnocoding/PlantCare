<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="APPLICATION_NAME" source="spring.application.name" />
    <springProperty name="LOG_FILE" source="logging.file.name" defaultValue="/app/logs/app.log" />
    <springProperty name="LOGSTASH_HOST" source="logstash.host" defaultValue="localhost" />

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{ISO8601} %-5p [%thread] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${APPLICATION_NAME}"}</customFields>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- TCP Socket Appender (sends JSON logs to Logstash) -->
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_HOST}:5000</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${APPLICATION_NAME}","environment":"local"}</customFields>
            <includeMdc>true</includeMdc>
            <mdc>true</mdc>
        </encoder>
        <!-- Buffer size for async operations -->
        <queueSize>512</queueSize>
        <!-- Keep trying connection even if failed -->
        <keepAliveDuration>5 minutes</keepAliveDuration>
    </appender>

    <!-- Async Appender for Logstash (non-blocking) -->
    <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="LOGSTASH" />
    </appender>

    <!-- Spring Boot default profiles -->
    <springProfile name="local">
        <logger name="com.backend" level="DEBUG" />
        <logger name="org.springframework.web" level="DEBUG" />
        <logger name="org.springframework.cloud.gateway" level="DEBUG" />
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ASYNC_LOGSTASH" />
        </root>
    </springProfile>

    <springProfile name="prod">
        <logger name="com.backend" level="INFO" />
        <logger name="org.springframework.web" level="INFO" />
        <logger name="org.springframework.cloud.gateway" level="INFO" />
        <root level="WARN">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ASYNC_LOGSTASH" />
        </root>
    </springProfile>

    <!-- Fallback if no profile is active -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="ASYNC_LOGSTASH" />
    </root>
</configuration>